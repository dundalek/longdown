{:tasks
 {:requires ([babashka.fs :as fs])

  compile
  {:doc "Compile squint sources"
   :task (shell "npx squint compile")}

  test
  {:doc "Compile and run tests"
   :depends [compile]
   :task (shell "node --test lib/longdown/lib_test.mjs")}

  test:watch
  {:doc "Watch and run tests on file change"
   :task (shell "watchexec -w src -w test bb run test")}

  clean {:doc "Remove compiled build files"
         :task (fs/delete-tree "lib")}

  build {:doc "Build the production bundle"
         :depends [clean compile]}

  publish {:depends [build]
           :task (shell "npm publish")}}}
